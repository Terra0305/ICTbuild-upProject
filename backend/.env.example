# Common
APP_ENV=development
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql+psycopg://refind:refind@localhost:5432/refind

# Auth
JWT_SECRET=change-me
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=14

# Public Data
LOST112_SERVICE_KEY=
LOST112_BASE_URL=

# Storage
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# AI
TEXT_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
IMAGE_MODEL_NAME=openai/clip-vit-base-patch32
FAISS_INDEX_DIR=/data/faiss
MATCH_DISPLAY_THRESHOLD=0.50
MATCH_NOTIFICATION_THRESHOLD=0.78

# Email
EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Scheduler
SYNC_CRON_SECRET=
